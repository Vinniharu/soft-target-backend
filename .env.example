APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# postgresql+asyncpg://<user>:<pass>@<host>:5432/<database>
DATABASE_URL=postgresql+asyncpg://softtarget:softtarget@localhost:5432/softtarget

# At least 32 bytes, base64-encoded. Generate with:
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(48)).decode())"
JWT_SECRET=replace-me-with-a-32-byte-random-value-base64-encoded
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

STORAGE_DIR=./var/softtarget

# Comma-separated list. Never "*" in production.
CORS_ALLOWED_ORIGINS=http://localhost:3000

LOG_LEVEL=info
ENABLE_DOCS=true
